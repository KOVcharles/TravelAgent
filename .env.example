# ================================================================
#  Hommey 智能旅行助手 - 环境变量配置
#  复制此文件为 .env 并填入实际值：
#    cp .env.example .env
# ================================================================

# ── LLM 模型配置（必填）─────────────────────────────────────────
HOMMEY_API_KEY=your-key                                 # API 密钥（必填）
HOMMEY_MODEL_NAME=deepseek-v4-flash                   # 模型名称
HOMMEY_BASE_URL=https://llm-nmdvomnybf87lb5m.cn-beijing.maas.aliyuncs.com/compatible-mode/v1  # API 地址
HOMMEY_TEMPERATURE=0.7                          # 生成随机性 (0-1)
HOMMEY_MAX_TOKENS=8192                          # 最大输出 token 数

# ── 系统配置 ────────────────────────────────────────────────────
HOMMEY_ENABLE_LLM=True                          # 是否启用 LLM
HOMMEY_LOG_LEVEL=INFO                           # 日志级别 (DEBUG/INFO/WARNING/ERROR)
HOMMEY_SYSTEM_MAX_RETRIES=3                     # 系统最大重试次数
HOMMEY_TIMEOUT=60                               # 请求超时（秒）

# ── RAG 知识库配置 ──────────────────────────────────────────────
HOMMEY_RAG_EMBEDDING_BACKEND=siliconflow             # siliconflow | local
HOMMEY_EMBEDDING_MODEL=BAAI/bge-m3                   # SiliconFlow BGE 模型；local 时可填本地模型路径
HOMMEY_EMBEDDING_API_KEY=                            # SiliconFlow API Key；也可用 SILICONFLOW_API_KEY
HOMMEY_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
HOMMEY_EMBEDDING_DIMENSION=1024                      # BAAI/bge-m3 输出维度
HOMMEY_EMBEDDING_BATCH_SIZE=32
HOMMEY_EMBEDDING_TIMEOUT_SEC=30
HOMMEY_RAG_DOCUMENTS_DIR=data/documents               # 文档目录
HOMMEY_RAG_KNOWLEDGE_BASE_PATH=data/rag_knowledge      # 向量库存储路径
HOMMEY_RAG_COLLECTION=business_travel_knowledge         # Milvus 集合名
HOMMEY_RAG_CHUNK_SIZE=600                               # 文档分块大小
HOMMEY_RAG_CHUNK_OVERLAP=100                            # 分块重叠长度
HOMMEY_RAG_TOP_K=3                                      # 检索返回 Top-K

# ── 熔断与重试（稳定性保障）────────────────────────────────────
HOMMEY_MAX_RETRIES=3                            # LLM 调用最大重试次数
HOMMEY_RETRY_BASE_DELAY_SEC=1.0                 # 重试初始延迟（秒）
HOMMEY_RETRY_MAX_DELAY_SEC=30.0                 # 重试最大延迟（秒）
HOMMEY_CIRCUIT_FAILURE_THRESHOLD=5              # 熔断触发阈值（连续失败次数）
HOMMEY_CIRCUIT_RECOVERY_TIMEOUT_SEC=60.0        # 熔断恢复等待时间（秒）
HOMMEY_CIRCUIT_HALF_OPEN_SUCCESSES=2            # 半开状态成功次数阈值
HOMMEY_HEALTH_CHECK_TIMEOUT_SEC=10.0            # 健康检查超时（秒）

# ── 记忆系统 ────────────────────────────────────────────────────
# 短期记忆（memory 或 redis）
HOMMEY_SHORT_TERM_BACKEND=memory                # 后端类型: memory | redis
HOMMEY_SHORT_TERM_MAX_TURNS=10                  # 滑动窗口轮数

# Redis 配置（短期记忆，SHORT_TERM_BACKEND=redis 时生效）
HOMMEY_REDIS_HOST=127.0.0.1
HOMMEY_REDIS_PORT=6379
HOMMEY_REDIS_DB=0
# Redis 密码（可选；无密码时保持空值）
HOMMEY_REDIS_PASSWORD=
HOMMEY_REDIS_KEY_PREFIX=hommey:short_term

# 长期记忆（file 或 postgres）
HOMMEY_LONG_TERM_BACKEND=file                   # 后端类型: file | postgres
HOMMEY_MEMORY_STORAGE_PATH=data/memory          # JSON 文件存储路径（file 模式）

# PostgreSQL 配置（长期记忆，LONG_TERM_BACKEND=postgres 时生效）
HOMMEY_POSTGRES_DSN=                            # 示例: postgresql://hommey:password@localhost:5432/hommey

# 管理员邮箱（逗号分隔）；这些邮箱注册后可访问 Skill 管理平台
HOMMEY_ADMIN_EMAILS=admin@example.com

# ── MCP 外部工具配置 ────────────────────────────────────────────
HOMMEY_MCP_AUTO_CONNECT=True                    # 是否自动连接 MCP Server
HOMMEY_MCP_CONNECT_TIMEOUT=10.0                 # 连接超时（秒）
HOMMEY_MCP_FILESYSTEM_ENABLED=False             # 是否启用文件系统 MCP Server
HOMMEY_MCP_FILESYSTEM_COMMAND=npx               # 启动命令

# ── Docker 专用（docker-compose 部署时使用）────────────────────
PG_PASSWORD=hommey123                           # PostgreSQL 密码
