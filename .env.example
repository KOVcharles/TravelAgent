# Required
ALIGO_API_KEY=your-api-key-here

# LLM
ALIGO_MODEL_NAME=deepseek-v3
ALIGO_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIGO_TEMPERATURE=0.7
ALIGO_MAX_TOKENS=8192
ALIGO_TIMEOUT=60

# Skills
ALIGO_SKILLS_ROOT=.claude/skills

# Memory
ALIGO_SHORT_TERM_BACKEND=memory
ALIGO_LONG_TERM_BACKEND=file
ALIGO_MEMORY_STORAGE_PATH=data/memory
ALIGO_POSTGRES_DSN=

# MCP
ALIGO_MCP_AUTO_CONNECT=true
ALIGO_MCP_FILESYSTEM_ENABLED=false
