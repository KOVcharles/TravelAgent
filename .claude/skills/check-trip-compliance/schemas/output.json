{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "status": {"enum": ["success", "insufficient_evidence"]},
    "verdict": {"enum": ["compliant", "non_compliant", "partial", "unknown"]},
    "checks": {"type": "array", "items": {"type": "object"}},
    "sources": {"type": "array", "items": {"type": "object"}},
    "unknown_items": {"type": "array", "items": {"type": "string"}},
    "missing_info": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "string"}
  },
  "required": ["status", "verdict", "checks", "sources", "unknown_items", "missing_info", "summary"],
  "additionalProperties": false
}
